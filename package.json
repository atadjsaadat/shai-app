{
  "name": "shai-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"const{execSync}=require('child_process');try{const ip=execSync('ipconfig getifaddr en0').toString().trim();console.log('\\n  Phone → http://'+ip+':3000\\n')}catch(e){}\" && next dev -H 0.0.0.0",
    "build": "NEXT_TURBOPACK=0 next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.108.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "typescript": "^5"
  }
}
